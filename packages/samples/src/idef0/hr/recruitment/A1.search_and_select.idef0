activity A1 "Поиск и отбор кандидатов" {
    I1 "Кадровая потребность"
    O1 "Список релевантных кандидатов"
    C1 "Внутренние политики компании"
    C2 "Описание вакансии"
    C3 "Рыночные условия"
    M1 "HR-специалист"
    M2 "Система трекинга кандидатов (ATS)"

    A11 "Публикация вакансии" : I1, C2, C3, M1 -> X111 "Поток откликов"
    A12 "Скрининг резюме"     : I[X111], C2, M1, M2 -> X112 "Кандидаты для скрининга"
    A13 "Первичное интервью"  : I[X112], C1, M1 -> X113[O1]
}
